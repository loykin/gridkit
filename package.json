{
  "name": "@loykin/gridkit",
  "version": "0.0.0-dev",
  "description": "A feature-rich React DataGrid component with virtualization, sorting, filtering, and pagination.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./styles": {
      "types": "./dist/styles.d.ts",
      "default": "./dist/styles.css"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc --noEmit && eslint src --ext .ts,.tsx && tsup && node scripts/build-css.mjs && echo 'declare const styles: string; export default styles;' > dist/styles.d.ts",
    "build:js": "tsup",
    "build:css": "node scripts/build-css.mjs",
    "dev": "concurrently \"tsup --watch\" \"pnpm --filter data-grid-playground dev\"",
    "type-check": "tsc --noEmit",
    "lint": "eslint src e2e --ext .ts,.tsx,.mjs",
    "lint:fix": "eslint src e2e --ext .ts,.tsx,.mjs --fix",
    "test": "vitest run",
    "test:consumer": "node scripts/verify-package-consumer.mjs",
    "test:e2e": "node --test e2e/*.test.mjs",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "clsx": "^2.1.1",
    "lucide-react": "^1.17.0",
    "zustand": "^5.0.14"
  },
  "peerDependencies": {
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/react-virtual": "^3.13.24",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "concurrently": "^10.0.3",
    "eslint": "^10.4.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "jsdom": "^29.1.1",
    "playwright": "^1.60.0",
    "prettier": "^3.8.4",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0",
    "vitest": "^4.1.8"
  },
  "keywords": [
    "react",
    "datagrid",
    "table",
    "virtualization",
    "tanstack"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/loykin/gridkit.git"
  },
  "homepage": "https://loykin.github.io/gridkit/playground/",
  "license": "MIT"
}
