{
  "name": "@loykin/gridkit",
  "version": "0.1.0",
  "description": "A feature-rich React DataGrid component with virtualization, sorting, filtering, and pagination.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./styles": "./dist/styles.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup && node_modules/.bin/tailwindcss -i src/styles/index.css -o dist/styles.css --minify",
    "build:js": "tsup",
    "build:css": "node_modules/.bin/tailwindcss -i src/styles/index.css -o dist/styles.css",
    "dev": "concurrently \"tsup --watch\" \"cd playground && npm run dev\"",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/react-virtual": "^3.13.23",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.546.0",
    "tailwind-merge": "^3.3.1",
    "tw-animate-css": "^1.4.0",
    "zustand": "^5.0.12"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.2.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "concurrently": "^9.2.1",
    "tailwindcss": "^4.2.2",
    "tsup": "^8.4.0",
    "typescript": "^5.9.3"
  },
  "keywords": [
    "react",
    "datagrid",
    "table",
    "virtualization",
    "tanstack"
  ],
  "license": "MIT"
}
